diff --git a/node_modules/axios/lib/core/encoreErrorReporter.js b/node_modules/axios/lib/core/encoreErrorReporter.js
new file mode 100644
index 0000000..75f9048
--- /dev/null
+++ b/node_modules/axios/lib/core/encoreErrorReporter.js
@@ -0,0 +1,21 @@
+let log = null;
+
+try {
+  if (typeof process !== 'undefined' && process.versions && process.versions.node) {
+    import('encore.dev/log').then((module) => {
+      log = module.default;
+    }).catch(() => {});
+  }
+} catch (e) {}
+
+export function reportAxiosError(response) {
+  if (log) {
+    log.error('axios error', {
+      status: response.status,
+      statusText: response.statusText,
+      method: response.config?.method,
+      url: response.config?.url,
+      data: response.data,
+    });
+  }
+}
